# WorldSim environment variables
#
# For local development with Docker Compose:
#   docker compose up
#
# This starts the PostGIS database and the API server. The DATABASE_URL below
# is pre-configured for the docker-compose.yml service names. After the
# containers are healthy, run migrations:
#   docker compose exec api alembic upgrade head
#
# Then seed Natural Earth boundaries:
#   docker compose exec api python -m app.db.seed.run_loader

DATABASE_URL=postgresql+asyncpg://worldsim:worldsim@localhost:5432/worldsim
